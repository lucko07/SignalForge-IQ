rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function userProfileEditableKeys() {
      return ["fullName", "email", "createdAt"];
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    function isValidUserProfileCreate() {
      return request.resource.data.keys().hasOnly(userProfileEditableKeys())
        && request.resource.data.fullName is string
        && request.resource.data.fullName.size() > 0
        && request.resource.data.email is string
        && request.resource.data.email.size() > 0
        && request.resource.data.createdAt == request.time;
    }

    function isValidUserProfileUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(["fullName", "email"])
        && request.resource.data.fullName is string
        && request.resource.data.fullName.size() > 0
        && request.resource.data.email is string
        && request.resource.data.email.size() > 0
        && request.resource.data.createdAt == resource.data.createdAt;
    }

    match /users/{userId} {
      allow create: if isOwner(userId) && isValidUserProfileCreate();
      allow read: if isOwner(userId) || isAdmin();
      allow update: if isOwner(userId) && isValidUserProfileUpdate();
      allow delete: if false;
    }

    match /signals/{signalId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /pendingSignals/{signalId} {
      allow read, create, update, delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
