rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function currentTermsVersion() {
      return "v1.0";
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    function hasMemberAccess() {
      return isSignedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.termsAccepted == true
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.privacyAccepted == true
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.termsVersion == currentTermsVersion()
        && (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin"
          || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.plan == "admin"
          || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.subscriptionActive == true
        );
    }

    function userProfileKeys() {
      return [
        "email",
        "fullName",
        "role",
        "plan",
        "subscriptionActive",
        "phoneVerified",
        "approved",
        "createdAt",
        "updatedAt",
        "currentPlan",
        "billingStatus",
        "stripeCustomerId",
        "stripeSubscriptionId",
        "cancelAtPeriodEnd",
        "subscriptionEndsAt",
        "webhookEnabled",
        "termsAccepted",
        "privacyAccepted",
        "termsVersion",
        "termsAcceptedAt"
      ];
    }

    function webhookDocumentKeys() {
      return [
        "enabled",
        "url",
        "secret",
        "assetFilters",
        "updatedAt"
      ];
    }

    function brokerConnectionKeys() {
      return [
        "provider",
        "mode",
        "connected",
        "lastValidatedAt",
        "paperTradingEnabled",
        "createdAt",
        "updatedAt"
      ];
    }

    function automationSettingsKeys() {
      return [
        "enabled",
        "provider",
        "mode",
        "symbolAllowlist",
        "longsEnabled",
        "shortsEnabled",
        "maxOpenPositions",
        "maxTradesPerDay",
        "sizingMode",
        "notionalUsd",
        "killSwitch",
        "createdAt",
        "updatedAt"
      ];
    }

    function canReadSensitiveAutomationRecords(userId) {
      return isOwner(userId) || isAdmin();
    }

    function legalFieldsAreValid() {
      return (!("termsAccepted" in request.resource.data) || request.resource.data.termsAccepted == true)
        && (!("privacyAccepted" in request.resource.data) || request.resource.data.privacyAccepted == true)
        && (!("termsVersion" in request.resource.data) || request.resource.data.termsVersion == currentTermsVersion())
        && (!("termsAcceptedAt" in request.resource.data) || request.resource.data.termsAcceptedAt is timestamp);
    }

    function webhookEnabledFieldIsValid() {
      return !("webhookEnabled" in request.resource.data) || request.resource.data.webhookEnabled is bool;
    }

    function webhookDocumentIsValid() {
      return request.resource.data.keys().hasOnly(webhookDocumentKeys())
        && request.resource.data.enabled is bool
        && request.resource.data.url is string
        && request.resource.data.secret is string
        && request.resource.data.assetFilters is list
        && request.resource.data.assetFilters.size() <= 100
        && request.resource.data.updatedAt == request.time;
    }

    function automationSettingsDocumentIsValid() {
      return request.resource.data.keys().hasOnly(automationSettingsKeys())
        && request.resource.data.enabled is bool
        && request.resource.data.provider == "alpaca"
        && request.resource.data.mode == "paper"
        && request.resource.data.symbolAllowlist is list
        && request.resource.data.symbolAllowlist.size() > 0
        && request.resource.data.symbolAllowlist.size() <= 25
        && request.resource.data.longsEnabled is bool
        && request.resource.data.shortsEnabled is bool
        && request.resource.data.maxOpenPositions is int
        && request.resource.data.maxOpenPositions > 0
        && request.resource.data.maxTradesPerDay is int
        && request.resource.data.maxTradesPerDay > 0
        && request.resource.data.sizingMode == "fixed_notional"
        && request.resource.data.notionalUsd is number
        && request.resource.data.notionalUsd > 0
        && request.resource.data.killSwitch is bool
        && request.resource.data.updatedAt == request.time;
    }

    function validAutomationSettingsCreate() {
      return automationSettingsDocumentIsValid()
        && request.resource.data.createdAt == request.time;
    }

    function validAutomationSettingsUpdate() {
      return automationSettingsDocumentIsValid()
        && (
          !("createdAt" in resource.data)
          || request.resource.data.createdAt == resource.data.createdAt
        );
    }

    function isValidUserProfileCreate() {
      return request.resource.data.keys().hasOnly(userProfileKeys())
        && request.resource.data.email is string
        && request.resource.data.email.size() > 0
        && (!("fullName" in request.resource.data) || (
          request.resource.data.fullName is string
          && request.resource.data.fullName.size() > 0
        ))
        && request.resource.data.role == "user"
        && request.resource.data.plan == "free"
        && request.resource.data.subscriptionActive == false
        && request.resource.data.phoneVerified is bool
        && request.resource.data.approved is bool
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time
        && webhookEnabledFieldIsValid()
        && legalFieldsAreValid();
    }

    function isValidUserProfileUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "email",
          "fullName",
          "phoneVerified",
          "approved",
          "createdAt",
          "updatedAt",
          "termsAccepted",
          "privacyAccepted",
          "termsVersion",
          "termsAcceptedAt"
        ])
        && request.resource.data.email is string
        && request.resource.data.email.size() > 0
        && (!("fullName" in request.resource.data) || (
          request.resource.data.fullName is string
          && request.resource.data.fullName.size() > 0
        ))
        && request.resource.data.role == resource.data.role
        && request.resource.data.plan == resource.data.plan
        && request.resource.data.subscriptionActive == resource.data.subscriptionActive
        && request.resource.data.phoneVerified is bool
        && request.resource.data.approved is bool
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.updatedAt == request.time
        && legalFieldsAreValid()
        && (!(resource.data.termsAccepted == true) || request.resource.data.termsAccepted == true)
        && (!(resource.data.privacyAccepted == true) || request.resource.data.privacyAccepted == true)
        && (
          !("termsVersion" in request.resource.data)
          || request.resource.data.termsVersion == currentTermsVersion()
        );
    }

    match /users/{userId} {
      allow create: if isOwner(userId) && isValidUserProfileCreate();
      allow read: if isOwner(userId);
      allow update: if isOwner(userId) && isValidUserProfileUpdate();
      allow delete: if false;

      match /webhooks/{webhookId} {
        allow read: if isOwner(userId);
        allow create, update: if false;
        allow delete: if false;
      }

      match /brokerConnections/{connectionId} {
        allow read: if canReadSensitiveAutomationRecords(userId);
        allow create, update, delete: if false;
      }

      match /automationSettings/{settingsId} {
        allow read: if canReadSensitiveAutomationRecords(userId);
        allow create: if isOwner(userId) && settingsId == "default" && validAutomationSettingsCreate();
        allow update: if isOwner(userId) && settingsId == "default" && validAutomationSettingsUpdate();
        allow delete: if false;
      }
    }

    match /signals/{signalId} {
      allow read: if true;
      allow create, update: if isAdmin();
      allow delete: if isAdmin() && resource.data.isTest == true;
    }

    match /pendingSignals/{signalId} {
      allow read, create, update, delete: if isAdmin();
    }

    match /trades/{tradeId} {
      allow read: if hasMemberAccess();
      allow create, update: if isAdmin();
      allow delete: if isAdmin() && resource.data.isTest == true;
    }

    match /performance_summary/{summaryId} {
      allow read: if hasMemberAccess();
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    match /executions/{executionId} {
      allow read: if isSignedIn() && (
        isAdmin()
        || (
          "uid" in resource.data
          && resource.data.uid is string
          && resource.data.uid == request.auth.uid
        )
      );
      allow create, update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
